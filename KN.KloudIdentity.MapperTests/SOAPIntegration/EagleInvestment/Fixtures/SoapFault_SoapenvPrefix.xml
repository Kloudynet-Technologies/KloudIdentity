<?xml version="1.0"?>
<!-- SOAP 1.1 Fault using the soapenv: prefix that Eagle envelopes use (HTTP 200 body) -->
<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/">
    <soapenv:Header/>
    <soapenv:Body>
        <soapenv:Fault>
            <faultcode>soapenv:Server</faultcode>
            <faultstring>EagleML task dispatch failed</faultstring>
            <detail>Internal stream error while processing runTaskRequest</detail>
        </soapenv:Fault>
    </soapenv:Body>
</soapenv:Envelope>
